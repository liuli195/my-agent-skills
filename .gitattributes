# ========================
# Text normalization
# ========================
* text=auto

*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.ps1 text eol=crlf
.gitignore text eol=lf
.gitattributes text eol=lf
gitignore text eol=lf

# Hooks and scripts must stay LF so Git for Windows can execute shebang scripts.
.githooks/* text eol=lf

# ========================
# Git LFS — large file tracking
# ========================

